{
    "version": 2,
    "buildCommand": "pnpm run build",
    "installCommand": "pnpm install",
    "framework": "nextjs",
    "outputDirectory": ".next",
    "env": {
        "NPM_CONFIG_UNSAFE_PERM": "true"
    },
    "git": {
        "deploymentEnabled": {
            "main": true,
            "next15": true
        }
    }
}
  
  